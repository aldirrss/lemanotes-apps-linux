# LemaNotes — Environment Configuration
# Copy this file to .env and fill in your values.
#
# SYNC_FROM_ENV controls where Supabase config is loaded from:
#
#   true  → URL and key are read from this file (read-only in the app).
#            Users only need to log in — the Setup dialog is hidden.
#            Useful for distributing the app with a pre-configured backend.
#
#   false → URL and key are configured via the app UI (Account → Setup Supabase…).
#            Values entered in the UI are saved to ~/.config/lemanotes/settings.json.
#            This is the default behavior when .env is absent.
#
LEMANOTES_SYNC_FROM_ENV=false

# Required when LEMANOTES_SYNC_FROM_ENV=true
LEMANOTES_SUPABASE_URL=https://xxxx.supabase.co
LEMANOTES_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
